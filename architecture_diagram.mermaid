graph TD
    subgraph External_Sources [External Data Sources]
        API[Financial APIs / Alpha Vantage]
    end

    subgraph Extraction_Layer [Extraction Layer - Python]
        PyScript[Python ETL Script]
    end

    subgraph Storage_Layer [Storage Layer - AWS S3]
        S3_Raw[S3 Bucket: Raw JSON Landing]
    end

    subgraph Snowflake_Medallion [Snowflake Data Cloud]
        subgraph Bronze_Layer [Bronze: Raw / Landing]
            SF_Landing[LANDING.MARKET_DATA_JSON]
        end

        subgraph Silver_Layer [Silver: Cleansed / Integrated]
            SF_Silver[STG_MARKET_DATA]
            SCD2[SCD Type 2: Historical Tracking]
        end

        subgraph Gold_Layer [Gold: Analytics Ready]
            SF_Gold[DIM_STOCKS / FACT_MARKET_TRENDS]
        end
    end

    subgraph Transformation_Layer [Transformation - dbt]
        dbt_Trans[dbt Models & Tests]
    end

    subgraph Consumption_Layer [Visualization]
        PBI[Power BI Dashboards]
    end

    %% Relationships
    API -->|Fetch JSON| PyScript
    PyScript -->|Upload| S3_Raw
    S3_Raw -->|Snowpipe / COPY INTO| SF_Landing
    
    SF_Landing --> dbt_Trans
    dbt_Trans --> SF_Silver
    SF_Silver --> SCD2
    SCD2 --> SF_Gold
    
    SF_Gold --> PBI

    %% Styling
    style Snowflake_Medallion fill:#f9f,stroke:#333,stroke-width:2px
    style S3_Raw fill:#ff9900,color:#fff
    style dbt_Trans fill:#ff694b,color:#fff
    style PBI fill:#f2c811,color:#000
